        "react-dom": "^19.1.1",
        "react-helmet-async": "^2.0.5",
        "react-router-dom": "^7.8.2",
        "sass": "^1.92.0",
        "web-vitals": "^5.1.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.2.0",
        "@types/node": "^24.3.0",
        "@types/react": "^19.1.12",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react-swc": "^4.0.1",
        "globals": "^16.3.0",
